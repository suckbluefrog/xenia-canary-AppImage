From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: suckbluefrog <suckbluefrog@proton.me>
Date: Sun, 07 Jun 2026 13:30:00 +0000
Subject: [PATCH] Use inline asm arm64 clock register reads for GCC

GCC's arm_acle.h does not provide the Clang/MSVC-style generic __arm_rsr64
helper used by Xenia. Read the arm64 counter registers with inline mrs asm
when compiling with GCC.

Signed-off-by: suckbluefrog <suckbluefrog@proton.me>
---
 src/xenia/base/clock_arm64.cc | 14 +++++++++++++-
 1 file changed, 13 insertions(+), 1 deletion(-)

diff --git a/src/xenia/base/clock_arm64.cc b/src/xenia/base/clock_arm64.cc
index 2021b15..de99d87 100644
--- a/src/xenia/base/clock_arm64.cc
+++ b/src/xenia/base/clock_arm64.cc
@@ -19,9 +19,21 @@
 constexpr uint32_t CNTFRQ_EL0 = ARM64_SYSREG(3, 3, 14, 0, 0);
 constexpr uint32_t CNTVCT_EL0 = ARM64_SYSREG(3, 3, 14, 0, 2);
 #define xe_cpu_mrs(reg) _ReadStatusReg(reg)
-#elif XE_COMPILER_CLANG || XE_COMPILER_GNUC
+#elif XE_COMPILER_CLANG
 #include <arm_acle.h>
 #define xe_cpu_mrs(reg) __arm_rsr64(#reg)
+#elif XE_COMPILER_GNUC
+static inline uint64_t xe_cpu_mrs_CNTFRQ_EL0() {
+  uint64_t value;
+  __asm__ volatile("mrs %0, cntfrq_el0" : "=r"(value));
+  return value;
+}
+static inline uint64_t xe_cpu_mrs_CNTVCT_EL0() {
+  uint64_t value;
+  __asm__ volatile("mrs %0, cntvct_el0" : "=r"(value));
+  return value;
+}
+#define xe_cpu_mrs(reg) xe_cpu_mrs_##reg()
 #else
 #error "No cpu instruction wrappers for current compiler implemented."
 #endif
